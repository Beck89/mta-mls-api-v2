{
  "name": "mta-mls-api-v2",
  "version": "1.0.0",
  "description": "MLS IDX API Server - Consumer-facing API for property search, detail, and typeahead",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed-neighborhoods": "tsx src/db/seed-neighborhoods.ts",
    "db:seed-areas": "tsx src/db/seed-search-areas.ts",
    "db:refresh-suggestions": "tsx src/db/refresh-suggestions.ts",
    "db:setup": "npm run db:migrate && npm run db:seed-areas && npm run db:refresh-suggestions",
    "drizzle:introspect": "drizzle-kit introspect",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mls",
    "real-estate",
    "api",
    "fastify",
    "drizzle"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.41.0",
    "fastify": "^5.2.1",
    "postgres": "^3.4.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "drizzle-kit": "^0.30.5",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
